{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Site Settings" %}
{% set selectedSubnavItem = 'globals' %}
{% set fullPageForm = true %}

{% if selectableSites is not defined %}
    {% if siteIds is defined %}
        {% set selectableSites = craft.app.sites.getEditableSites()|filter(s => s.id in siteIds) %}
    {% else %}
        {% set selectableSites = craft.app.sites.getEditableSites() %}
    {% endif %}
{% endif %}

{% if selectedSite is not defined %}
    {% if selectedSiteId is defined %}
        {% set selectedSite = craft.app.sites.getSiteById(selectedSiteId) %}
    {% elseif requestedSite and requestedSite in selectableSites %}
        {% set selectedSite = requestedSite %}
    {% else %}
        {% set selectedSite = selectableSites|length ? selectableSites|first : craft.app.sites.getPrimarySite() %}
    {% endif %}
{% endif %}

{% set crumbs = [
    {
        id: 'site-crumb',
        icon: 'world',
        iconAltText: 'Site'|t('app'),
        label: selectedSite.name|t('site'),
        menu: {
            items: siteMenuItems(selectableSites, selectedSite),
            label: 'Select site'|t('app')
        }
    },
    { label: 'LLMify', url: cpUrl('llmify') },
] %}

{% set otherSites = selectableSites|filter(s => s.id != siteId) %}

{% block actionButton %}
    <div class="flex">
        {% if otherSites|length %}
            {% include 'llmify/settings/_copy/menu' with {
                sites: otherSites,
                path: 'llmify/globals',
                params: { site: selectedSite.handle },
            } only %}
        {% endif %}
        {{ parent() }}
    </div>
{% endblock %}

{% block content %}
    {{ actionInput('llmify/globals/save-settings') }}
    {{ redirectInput('llmify/globals') }}
    {{ hiddenInput('siteId', siteId) }}

    {{ forms.lightswitchField({
        label: 'Enable for Site',
        instructions: "Activates LLM content generation for this entire site. If disabled, no llms.txt file will be created for this site's content.",
        id: 'enabled',
        name: 'enabled',
        on: settings.enabled,
        first: true,
    }) }}

    {{ forms.textField({
        label: 'LLM Title',
        instructions: "Primary heading in `llms.txt`. Supports Twig, e.g. `{name}` for the site name.",
        id: 'llmTitle',
        name: 'llmTitle',
        value: settings.llmTitle,
    }) }}

    {{ forms.textField({
        label: 'LLM Description',
        instructions: "Short site description shown below the title. Supports Twig, e.g. `{name}`.",
        id: 'llmDescription',
        name: 'llmDescription',
        value: settings.llmDescription,
    }) }}

    {{ forms.textField({
        label: 'LLM Note',
        instructions: "Optional footer note appended to `llms.txt`. Supports Twig.",
        id: 'llmNote',
        name: 'llmNote',
        value: settings.llmNote,
    }) }}

    {% set frontMatterFieldsCols = {
        handle: {
          type: 'select',
          heading: 'Field',
          options: frontMatterFieldOptions,
        },
        enabled: {
          type: 'lightswitch',
          heading: 'Enabled',
        },
        label: {
          type: 'singleline',
          heading: 'Output Label',
          placeholder: 'e.g., title',
        }
      } %}

    {{ forms.editableTableField({
      label: "Front Matter Fields",
      instructions: 'Configure which fields to include in the YAML front matter for markdown pages. These settings apply to all sections unless overridden at the section or entry level.',
      name: 'frontMatterFields',
      id: 'frontMatterFields',
      cols: frontMatterFieldsCols,
      rows: settings.frontMatterFields,
      addRowLabel: "Add a field",
      allowAdd: true,
      allowDelete: true,
      allowReorder: true,
    }) }}
{% endblock %}
